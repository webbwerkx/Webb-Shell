# Matugen generated colors for fish shell
set -U fish_color_normal "{{colors.on_surface.default.hex}}"
set -U fish_color_command "{{colors.primary.default.hex}}"
set -U fish_color_param "{{colors.secondary.default.hex}}"
set -U fish_color_redirection "{{colors.tertiary.default.hex}}"
set -U fish_color_comment "{{colors.outline.default.hex}}"
set -U fish_color_error "{{colors.error.default.hex}}"
set -U fish_color_match --background="{{colors.surface_variant.default.hex}}"
set -U fish_color_selection --background="{{colors.surface_variant.default.hex}}"
set -U fish_color_autosuggestion "{{colors.on_surface_variant.default.hex}}"
