{
  "id": "nvim",
  "label": "Neovim",
  "icon": "code",
  "binds": [
    { "keys": "i",              "desc": "Insert before cursor" },
    { "keys": "I",              "desc": "Insert at line start" },
    { "keys": "a",              "desc": "Insert after cursor" },
    { "keys": "A",              "desc": "Insert at line end" },
    { "keys": "o",              "desc": "New line below, insert" },
    { "keys": "O",              "desc": "New line above, insert" },
    { "keys": "Esc",            "desc": "Return to normal mode" },
    { "keys": "v",              "desc": "Visual character mode" },
    { "keys": "V",              "desc": "Visual line mode" },
    { "keys": "CTRL+V",         "desc": "Visual block mode" },
    { "keys": ":w",             "desc": "Save file" },
    { "keys": ":q",             "desc": "Quit" },
    { "keys": ":wq",            "desc": "Save and quit" },
    { "keys": ":q!",            "desc": "Force quit without saving" },
    { "keys": ":wa",            "desc": "Save all buffers" },
    { "keys": "u",              "desc": "Undo" },
    { "keys": "CTRL+R",         "desc": "Redo" },
    { "keys": "dd",             "desc": "Delete (cut) line" },
    { "keys": "D",              "desc": "Delete to end of line" },
    { "keys": "yy",             "desc": "Yank (copy) line" },
    { "keys": "p",              "desc": "Paste after cursor" },
    { "keys": "P",              "desc": "Paste before cursor" },
    { "keys": "x",              "desc": "Delete character under cursor" },
    { "keys": "X",              "desc": "Delete character before cursor" },
    { "keys": "r",              "desc": "Replace character" },
    { "keys": "R",              "desc": "Enter replace mode" },
    { "keys": "~",              "desc": "Toggle case of character" },
    { "keys": ".",              "desc": "Repeat last change" },
    { "keys": "ciw",            "desc": "Change inner word" },
    { "keys": "cit",            "desc": "Change inner tag" },
    { "keys": "ci\"",           "desc": "Change inside double quotes" },
    { "keys": "ci'",            "desc": "Change inside single quotes" },
    { "keys": "ci(",            "desc": "Change inside parentheses" },
    { "keys": "ca(",            "desc": "Change around parentheses" },
    { "keys": "diw",            "desc": "Delete inner word" },
    { "keys": "yiw",            "desc": "Yank inner word" },
    { "keys": "gg",             "desc": "Go to first line" },
    { "keys": "G",              "desc": "Go to last line" },
    { "keys": "0",              "desc": "Go to start of line" },
    { "keys": "^",              "desc": "Go to first non-blank character" },
    { "keys": "$",              "desc": "Go to end of line" },
    { "keys": "w",              "desc": "Jump forward to start of word" },
    { "keys": "W",              "desc": "Jump forward to start of WORD" },
    { "keys": "b",              "desc": "Jump backward to start of word" },
    { "keys": "e",              "desc": "Jump forward to end of word" },
    { "keys": "%",              "desc": "Jump to matching bracket" },
    { "keys": "f+char",         "desc": "Jump to next occurrence of char" },
    { "keys": "F+char",         "desc": "Jump to previous occurrence of char" },
    { "keys": "t+char",         "desc": "Jump before next occurrence of char" },
    { "keys": "CTRL+D",         "desc": "Scroll down half page" },
    { "keys": "CTRL+U",         "desc": "Scroll up half page" },
    { "keys": "CTRL+F",         "desc": "Scroll down full page" },
    { "keys": "CTRL+B",         "desc": "Scroll up full page" },
    { "keys": "zz",             "desc": "Centre screen on cursor" },
    { "keys": "zt",             "desc": "Scroll so cursor is at top" },
    { "keys": "zb",             "desc": "Scroll so cursor is at bottom" },
    { "keys": "/",              "desc": "Search forward" },
    { "keys": "?",              "desc": "Search backward" },
    { "keys": "n",              "desc": "Next search result" },
    { "keys": "N",              "desc": "Previous search result" },
    { "keys": "*",              "desc": "Search word under cursor forward" },
    { "keys": "#",              "desc": "Search word under cursor backward" },
    { "keys": ":%s/old/new/g",  "desc": "Replace all occurrences in file" },
    { "keys": ":s/old/new/g",   "desc": "Replace all occurrences on line" },
    { "keys": "CTRL+W+H",       "desc": "Move to left split" },
    { "keys": "CTRL+W+J",       "desc": "Move to split below" },
    { "keys": "CTRL+W+K",       "desc": "Move to split above" },
    { "keys": "CTRL+W+L",       "desc": "Move to right split" },
    { "keys": "CTRL+W+V",       "desc": "Vertical split" },
    { "keys": "CTRL+W+S",       "desc": "Horizontal split" },
    { "keys": "CTRL+W+Q",       "desc": "Close split" },
    { "keys": "CTRL+W+=",       "desc": "Equalise split sizes" },
    { "keys": "CTRL+W+R",       "desc": "Rotate windows" },
    { "keys": "gt",             "desc": "Next tab" },
    { "keys": "gT",             "desc": "Previous tab" },
    { "keys": ":tabnew",        "desc": "Open new tab" },
    { "keys": ":tabc",          "desc": "Close tab" },
    { "keys": "gd",             "desc": "Go to definition (LSP)" },
    { "keys": "gD",             "desc": "Go to declaration (LSP)" },
    { "keys": "gr",             "desc": "Go to references (LSP)" },
    { "keys": "gi",             "desc": "Go to implementation (LSP)" },
    { "keys": "K",              "desc": "Hover documentation (LSP)" },
    { "keys": "CTRL+K",         "desc": "Signature help (LSP)" },
    { "keys": "[d",             "desc": "Previous diagnostic (LSP)" },
    { "keys": "]d",             "desc": "Next diagnostic (LSP)" },
    { "keys": "za",             "desc": "Toggle fold" },
    { "keys": "zo",             "desc": "Open fold" },
    { "keys": "zc",             "desc": "Close fold" },
    { "keys": "zR",             "desc": "Open all folds" },
    { "keys": "zM",             "desc": "Close all folds" },
    { "keys": "q+letter",       "desc": "Record macro" },
    { "keys": "@+letter",       "desc": "Play macro" },
    { "keys": "@@",             "desc": "Replay last macro" },
    { "keys": ">>",             "desc": "Indent line right" },
    { "keys": "<<",             "desc": "Indent line left" },
    { "keys": ":set number",    "desc": "Show line numbers" },
    { "keys": ":set spell",     "desc": "Enable spell check" },
    { "keys": "CTRL+N",         "desc": "Autocomplete next (insert mode)" },
    { "keys": "CTRL+P",         "desc": "Autocomplete previous (insert mode)" }
  ]
}
