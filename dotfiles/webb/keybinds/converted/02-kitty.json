{
  "id": "kitty",
  "label": "Kitty",
  "icon": "terminal",
  "binds": [
    {
      "keys": "CTRL+SHIFT+C",
      "desc": "Copy to clipboard"
    },
    {
      "keys": "CTRL+SHIFT+V",
      "desc": "Paste from clipboard"
    },
    {
      "keys": "CTRL+SHIFT+S",
      "desc": "Paste from selection"
    },
    {
      "keys": "SHIFT+Insert",
      "desc": "Paste from selection (alt)"
